# Nam Hieu Booking — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — NEVER commit it.
#
# After setting values, run:  npm run dev:env
# This writes public/env.js (also gitignored) which the browser reads.
#
# Where to find these values:
#   Supabase Dashboard → Project Settings → API
#   URL:      "Project URL" field
#   ANON KEY: "anon" / "public" key  ← safe to expose (RLS protects data)
#
# WARNING: NEVER put the "service_role" key here. It bypasses RLS entirely.

SUPABASE_URL=
SUPABASE_ANON_KEY=
